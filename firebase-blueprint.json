{
  "entities": {
    "Incident": {
      "title": "Incident",
      "description": "A reported police incident",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Closed"] },
        "date": { "type": "string" },
        "location": { "type": "string" },
        "officerId": { "type": "string" },
        "filingStation": { "type": "string" },
        "recordingOfficerName": { "type": "string" },
        "recordingOfficerRank": { "type": "string" },
        "type": { "type": "string", "enum": ["Crime", "Traffic"] },
        "category": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "title", "status", "date", "location", "officerId", "type", "category"]
    },
    "Officer": {
      "title": "Officer",
      "description": "A police officer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "badgeNumber": { "type": "string" },
        "rank": { "type": "string" },
        "email": { "type": "string" },
        "station": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "On Leave", "Suspended"] }
      },
      "required": ["id", "name", "badgeNumber", "rank", "email", "status"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "A task assigned to an officer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Completed"] },
        "dueDate": { "type": "string" },
        "incidentId": { "type": "string" },
        "officerId": { "type": "string" }
      },
      "required": ["id", "title", "status", "dueDate", "officerId"]
    },
    "Report": {
      "title": "Report",
      "description": "An official police report",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["Submitted", "Pending Review"] },
        "date": { "type": "string" },
        "location": { "type": "string" },
        "officerId": { "type": "string" },
        "filingStation": { "type": "string" },
        "recordingOfficerName": { "type": "string" },
        "recordingOfficerRank": { "type": "string" },
        "type": { "type": "string", "enum": ["Crime", "Traffic"] },
        "category": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "title", "status", "date", "location", "officerId", "type", "category"]
    },
    "User": {
      "title": "User",
      "description": "A system user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Officer"] },
        "avatar": { "type": "string" }
      },
      "required": ["id", "name", "email", "role"]
    }
  },
  "firestore": {
    "/incidents": { "schema": "Incident", "description": "Collection of police incidents" },
    "/officers": { "schema": "Officer", "description": "Collection of police officers" },
    "/assignments": { "schema": "Assignment", "description": "Collection of officer assignments" },
    "/reports": { "schema": "Report", "description": "Collection of official reports" },
    "/users": { "schema": "User", "description": "Collection of system users" }
  }
}

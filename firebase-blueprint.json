{
  "entities": {
    "CrimeReport": {
      "title": "Crime Report",
      "description": "An anonymous crime report or tip submitted by a citizen.",
      "type": "object",
      "properties": {
        "description": { "type": "string", "description": "The detailed description of the incident." },
        "type": { "type": "string", "enum": ["crime", "traffic"], "description": "The category of the incident." },
        "location": { "type": "string", "description": "The location where the incident occurred." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the report was submitted." },
        "mediaUrls": { "type": "array", "items": { "type": "string" }, "description": "Links to attached photos or videos." },
        "status": { "type": "string", "enum": ["pending", "investigating", "resolved"], "description": "Current status of the report." },
        "authorUid": { "type": "string", "description": "The anonymous UID of the reporter." }
      },
      "required": ["description", "type", "timestamp", "authorUid"]
    },
    "EmergencyHotline": {
      "title": "Emergency Hotline",
      "description": "A contact number for emergency services.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the station or service." },
        "nameAm": { "type": "string", "description": "Amharic name of the station or service." },
        "phone": { "type": "string", "description": "The phone number to call." },
        "zone": { "type": "string", "description": "The geographical zone covered." }
      },
      "required": ["name", "phone"]
    },
    "NewsAlert": {
      "title": "News & Alert",
      "description": "Official police announcements and safety alerts.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The headline of the news or alert." },
        "titleAm": { "type": "string", "description": "The Amharic headline." },
        "content": { "type": "string", "description": "The full text of the announcement." },
        "contentAm": { "type": "string", "description": "The Amharic full text." },
        "type": { "type": "string", "enum": ["alert", "news", "missing"], "description": "The type of announcement." },
        "image": { "type": "string", "description": "URL to a related image." },
        "date": { "type": "string", "format": "date", "description": "The date of the announcement." },
        "timestamp": { "type": "string", "format": "date-time", "description": "Server-side timestamp." }
      },
      "required": ["title", "content", "type", "date"]
    },
    "PoliceStation": {
      "title": "Police Station",
      "description": "Information about a local police station.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the station." },
        "nameAm": { "type": "string", "description": "The Amharic name." },
        "location": { "type": "string", "description": "General location description." },
        "distance": { "type": "string", "description": "Distance from the user (calculated client-side or stored for reference)." },
        "phone": { "type": "string", "description": "Contact phone number." },
        "coordinates": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } }, "description": "GPS coordinates." }
      },
      "required": ["name", "phone"]
    }
  },
  "firestore": {
    "/crime_reports/{reportId}": { "schema": "CrimeReport", "description": "Collection of anonymous crime reports." },
    "/emergency_hotlines/{hotlineId}": { "schema": "EmergencyHotline", "description": "Collection of emergency contact numbers." },
    "/news_alerts/{alertId}": { "schema": "NewsAlert", "description": "Collection of official news and safety alerts." },
    "/police_stations/{stationId}": { "schema": "PoliceStation", "description": "Collection of local police stations." }
  }
}
